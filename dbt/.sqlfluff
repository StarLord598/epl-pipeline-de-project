[sqlfluff]
dialect = duckdb
templater = jinja
max_line_length = 120

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

# Disable opinionated structural rules that conflict with readability
[sqlfluff:rules:structure.column_order]
enabled = False

[sqlfluff:rules:ambiguous.order_by]
enabled = False

[sqlfluff:rules:structure.simple_case]
enabled = False

[sqlfluff:rules:aliasing.table]
force_enable = False

[sqlfluff:rules:references.consistent]
enabled = False

[sqlfluff:rules:convention.casting_style]
preferred_type_casting_style = consistent
