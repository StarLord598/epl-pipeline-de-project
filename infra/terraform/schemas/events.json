[
  {"name": "event_id",       "type": "STRING",  "mode": "REQUIRED", "description": "Unique event UUID"},
  {"name": "match_id",       "type": "INTEGER", "mode": "REQUIRED", "description": "Match this event belongs to"},
  {"name": "index_num",      "type": "INTEGER", "mode": "NULLABLE", "description": "Event sequence index within match"},
  {"name": "period",         "type": "INTEGER", "mode": "NULLABLE", "description": "Match period (1=first half, 2=second half)"},
  {"name": "minute",         "type": "INTEGER", "mode": "NULLABLE", "description": "Minute of the event"},
  {"name": "second",         "type": "INTEGER", "mode": "NULLABLE", "description": "Second within the minute"},
  {"name": "event_type",     "type": "STRING",  "mode": "NULLABLE", "description": "Type of event (Shot, Pass, Carry, etc.)"},
  {"name": "team_id",        "type": "INTEGER", "mode": "NULLABLE", "description": "Team performing the action"},
  {"name": "team_name",      "type": "STRING",  "mode": "NULLABLE", "description": "Team name"},
  {"name": "player_id",      "type": "INTEGER", "mode": "NULLABLE", "description": "Player performing the action"},
  {"name": "player_name",    "type": "STRING",  "mode": "NULLABLE", "description": "Player name"},
  {"name": "position_name",  "type": "STRING",  "mode": "NULLABLE", "description": "Player position"},
  {"name": "location_x",     "type": "FLOAT64", "mode": "NULLABLE", "description": "X coordinate on pitch (0-120)"},
  {"name": "location_y",     "type": "FLOAT64", "mode": "NULLABLE", "description": "Y coordinate on pitch (0-80)"},
  {"name": "sub_type",       "type": "STRING",  "mode": "NULLABLE", "description": "Event sub-type"},
  {"name": "outcome",        "type": "STRING",  "mode": "NULLABLE", "description": "Outcome of the event"},
  {"name": "raw_json",       "type": "JSON",    "mode": "NULLABLE", "description": "Full event JSON"},
  {"name": "ingested_at",    "type": "TIMESTAMP","mode": "REQUIRED","description": "Ingestion timestamp (partition key)"}
]
