# ===========================================
# EPL Pipeline — Environment Configuration
# ===========================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/keys/gcp-service-account.json

# --- Data Sources ---
FOOTBALL_DATA_API_KEY=your-key-from-football-data.org
API_FOOTBALL_KEY=your-key-from-api-football

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=change-me

# --- BigQuery Datasets ---
BQ_RAW_DATASET=epl_raw
BQ_STAGING_DATASET=epl_staging
BQ_MART_DATASET=epl_mart

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
